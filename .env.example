# NextAuth - Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Application
NODE_ENV="development"
NEXTAUTH_URL="http://localhost:3000"

# Database (Development - managed by Docker Compose)
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/purchase_organizer?schema=public"

# Production Database (uncomment and configure for production)
# POSTGRES_USER="postgres"
# POSTGRES_PASSWORD=""  # CHANGE THIS IN PRODUCTION!
# POSTGRES_DB="purchase_organizer"
# POSTGRES_PORT="5432"

# Production App Port (uncomment for production)
# APP_PORT="3000"

# File Upload
UPLOAD_DIR="public/uploads"
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/webp"
